# ---- Client (Vite) environment variables ----
# Copy to `.env` (or `.env.local`) and fill in. Vite only exposes vars
# prefixed with VITE_ to the browser.

# Base URL of the backend API (note the trailing /api).
VITE_API_URL=http://localhost:3000/api

# Google OAuth Web Client ID (from Google Cloud Console > Credentials).
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
