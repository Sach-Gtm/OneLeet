# ---- Server environment variables ----
# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# Node environment: "development" or "production".
# In production, auth cookies switch to SameSite=None; Secure (required for the
# Vercel <-> Railway/Render cross-site setup).
NODE_ENV=development

# Port the API listens on. Railway/Render inject their own PORT.
PORT=3000

# MongoDB connection string (MongoDB Atlas or local mongod).
MONGO_URI=mongodb://127.0.0.1:27017/oneleet

# Secret used to sign JWTs. Use a long random string.
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# Frontend origin(s) allowed by CORS. Comma-separate multiple origins.
# e.g. http://localhost:5173,https://oneleet.vercel.app
CLIENT_URL=http://localhost:5173

# Cloudinary (media uploads — already used for PDF notes)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# AI provider abstraction (used by the AI Tools feature, added later).
# Supported values will include: gemini
AI_PROVIDER=gemini
GEMINI_API_KEY=

# Email — powers OTP verification + password-reset emails. Leave all blank to
# keep email off (signups stay active without OTP; reset links get logged).
#
# PREFERRED: Brevo HTTP API. Works on hosts that block SMTP (e.g. Render free
# tier, where Gmail SMTP times out). Free tier ~300/day, no domain required —
# just verify a sender address in Brevo (Senders → verify EMAIL_FROM_EMAIL).
BREVO_API_KEY=
EMAIL_FROM_EMAIL=oneleethelp@gmail.com
EMAIL_FROM_NAME=OneLeet
#
# FALLBACK: Gmail SMTP (only used if BREVO_API_KEY is unset). Works locally but
# NOT on Render free tier. EMAIL_PASS must be a Gmail "App Password".
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
